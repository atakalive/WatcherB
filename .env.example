# Discord
DISCORD_BOT_TOKEN=your_bot_token_here
CHANNEL_ID=0
SEND_ENABLED=true

# GitLab (pipeline card issue links)
GITLAB_BASE_URL=https://gitlab.com/YOUR_NAMESPACE

# GitLab Issue Browser
GITLAB_URL=https://gitlab.com              # GitLab instance URL (default: https://gitlab.com)
GITLAB_TOKEN=                              # Personal access token (read_api scope; required for private repos)
GITLAB_PROJECTS=YOUR_NAMESPACE/project1,YOUR_NAMESPACE/project2  # Comma-separated full project paths
